{
  "info": {
    "name": "CMPG Northwind API REST Videojuegos",
    "description": "Colección Postman para probar la API REST Flask + MySQL + Angular. Base Northwind adaptada a tienda de videojuegos CMPG.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5000/api"
    }
  ],
  "item": [
    {
      "name": "00 Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@cmpg.com\",\n  \"password\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "00.1 Listar usuarios",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/users"
      }
    },
    {
      "name": "01 Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "02 Listar categorias",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/categories"
      }
    },
    {
      "name": "03 Crear categoria de prueba",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/categories",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"category_name\": \"Ofertas Gamer\",\n  \"description\": \"Categoría creada desde Postman para probar POST\"\n}"
        }
      }
    },
    {
      "name": "04 Listar productos",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/products"
      }
    },
    {
      "name": "05 Buscar productos por texto",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/products?search=zelda"
      }
    },
    {
      "name": "06 Filtrar productos por categoria Nintendo",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/products?category_id=5"
      }
    },
    {
      "name": "07 Ver producto por ID",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/products/1"
      }
    },
    {
      "name": "08 Crear producto para pruebas",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product_name\": \"Juego API Test Deluxe\",\n  \"supplier_id\": 2,\n  \"category_id\": 2,\n  \"quantity_per_unit\": \"Código digital de prueba\",\n  \"unit_price\": 399.99,\n  \"units_in_stock\": 20,\n  \"units_on_order\": 0,\n  \"reorder_level\": 5,\n  \"discontinued\": false\n}"
        }
      }
    },
    {
      "name": "09 Actualizar producto creado - cambia el ID si hace falta",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/products/33",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product_name\": \"Juego API Test Deluxe Actualizado\",\n  \"supplier_id\": 2,\n  \"category_id\": 2,\n  \"quantity_per_unit\": \"Código digital actualizado\",\n  \"unit_price\": 499.99,\n  \"units_in_stock\": 15,\n  \"units_on_order\": 0,\n  \"reorder_level\": 3,\n  \"discontinued\": false\n}"
        }
      }
    },
    {
      "name": "10 Eliminar producto creado - cambia el ID si hace falta",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/products/33"
      }
    },
    {
      "name": "11 Listar proveedores",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/suppliers"
      }
    },
    {
      "name": "12 Listar clientes",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/customers"
      }
    },
    {
      "name": "13 Listar empleados",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/employees"
      }
    },
    {
      "name": "14 Listar ordenes",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/orders"
      }
    },
    {
      "name": "15 Ver orden por ID con detalles",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/orders/1"
      }
    },
    {
      "name": "16 Crear orden con detalles",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{base_url}}/orders",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer_id\": \"GMR01\",\n  \"employee_id\": 1,\n  \"ship_name\": \"Pedido API CMPG\",\n  \"ship_address\": \"Av. Programación Web 123\",\n  \"ship_city\": \"Zamora\",\n  \"ship_country\": \"Mexico\",\n  \"details\": [\n    {\n      \"product_id\": 8,\n      \"unit_price\": 599.00,\n      \"quantity\": 1,\n      \"discount\": 0\n    },\n    {\n      \"product_id\": 29,\n      \"unit_price\": 500.00,\n      \"quantity\": 2,\n      \"discount\": 0\n    }\n  ]\n}"
        }
      }
    }
  ]
}